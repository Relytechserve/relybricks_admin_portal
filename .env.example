# ── Local-only: rename to `.env.local` and fill values; Next.js reads `.env.local` on your machine — not used by Vercel.
#
# ── Vercel: add NEXT_PUBLIC_SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, and (usually omit) BANK_STATEMENTS_ROOT in
# Project → Settings → Environment Variables. The reconciliation scan walks BANK_STATEMENTS_ROOT on the *server filesystem*;
# a path on your laptop is invisible to deployed lambdas — run scans from `npm run dev` locally, or add Storage-based scanning later.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for creating customer logins and resetting passwords (Supabase Dashboard > Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Financial reconciliation: absolute OS path on the machine running Next.js (folder of PDFs/CSVs; scanned recursively)
BANK_STATEMENTS_ROOT=
# Optional: password for encrypted PDF statements (do not commit real values)
BANK_STATEMENT_PASSWORD=

# Optional for invoice email sending (Milestone C)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
