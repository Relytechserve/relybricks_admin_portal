NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for creating customer logins and resetting passwords (Supabase Dashboard > Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Financial reconciliation: absolute path to local folder of statement PDFs/CSVs (scanned recursively)
BANK_STATEMENTS_ROOT=
# Optional: password for encrypted PDF statements (do not commit real values)
BANK_STATEMENT_PASSWORD=

# Optional for invoice email sending (Milestone C)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
